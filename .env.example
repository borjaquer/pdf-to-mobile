# ============================================
# PDF-to-Mobile — Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena las claves.
# Ninguna de estas claves se expone en el bundle
# a menos que tengan el prefijo VITE_.
#
# DESPLIEGUE EN RENDER (Render Dashboard):
#   Settings → Environment → Add Environment Variable
#   Añade VITE_GEMINI_API_KEY y VITE_OPENROUTER_API_KEY.
#   No olvides marcar "Sync: false" para que no se
#   sobrescriban desde render.yaml.

# DeepSeek API (PRIMARIO)
# Consíguela en: https://platform.deepseek.com/api_keys
# Modelo: deepseek-chat (V3). Precio: ~$0.27/M input, ~$1.10/M output tokens.
# Contexto: 128K tokens. Compatible con OpenAI SDK.
VITE_DEEPSEEK_API_KEY=

# OpenRouter API (FALLBACK)
# Consíguela en: https://openrouter.ai/keys
# Modelos :free disponibles: 20 RPM, 200 RPD
VITE_OPENROUTER_API_KEY=

# Firecrawl Search API (OPCIONAL — búsqueda web en el chat)
# Consíguela en: https://firecrawl.dev/app/api-keys
# Plan gratuito: 500 créditos/mes
VITE_FIRECRAWL_API_KEY=

# Supabase (OPCIONAL — almacenamiento de PDFs)
# Consíguelas en: https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
